{
  "include": ["src", "tests"],
  "exclude": [
    "**/__pycache__",
    "**/.pytest_cache",
    "**/.venv",
    "runs",
    "reference_images"
  ],
  "venvPath": ".",
  "venv": ".venv",
  "pythonVersion": "3.11",
  "typeCheckingMode": "basic",
  "useLibraryCodeForTypes": true,
  "reportMissingImports": "error",
  "reportMissingTypeStubs": "none"
}
