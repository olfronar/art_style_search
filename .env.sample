# Anthropic API key for Claude (reasoning/analysis) — required if using --reasoning-provider anthropic
ANTHROPIC_API_KEY=

# Google API key for Gemini models (captioning/generation) — always required
GOOGLE_API_KEY=

# Z.AI API key for GLM-5.1 (reasoning/analysis) — required if using --reasoning-provider zai
ZAI_API_KEY=
