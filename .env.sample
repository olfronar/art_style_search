# Anthropic API key for Claude (reasoning/analysis) — required if using --reasoning-provider anthropic
ANTHROPIC_API_KEY=

# Google API key for Gemini models (captioning/generation) — always required
GOOGLE_API_KEY=

# Z.AI API key for GLM-5.1 (reasoning/analysis) — required if using --reasoning-provider zai
ZAI_API_KEY=

# OpenAI API key for GPT-5.4 (reasoning/analysis) — required if using --reasoning-provider openai
OPENAI_API_KEY=

# xAI API key for Grok 4.20 (reasoning and/or image comparison) — required if using
# --reasoning-provider xai or --comparison-provider xai
XAI_API_KEY=
